<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!--    Form View-->
    <record id="sale_order_milestone_views_form" model="ir.ui.view">
        <field name="name">sale.order.milestone.views.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='order_lines']/field[@name='order_line']/list/field[@name='product_uom_qty']"
                   position="before">
                <field name="milestone"/>
            </xpath>
            <xpath expr="//header" position="inside">
                <button string="Create Project" name="create_project" type="object"/>
            </xpath>
        </field>
    </record>
</odoo>